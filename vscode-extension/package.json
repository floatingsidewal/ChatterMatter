{
  "name": "chattermatter-vscode",
  "displayName": "ChatterMatter",
  "description": "Inline comments and AI review for Markdown documents",
  "version": "0.1.0",
  "publisher": "chattermatter",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chattermatter.addComment",
        "title": "ChatterMatter: Add Comment"
      },
      {
        "command": "chattermatter.resolveComment",
        "title": "ChatterMatter: Resolve Comment",
        "icon": "$(check)"
      },
      {
        "command": "chattermatter.deleteComment",
        "title": "ChatterMatter: Delete Comment",
        "icon": "$(trash)"
      },
      {
        "command": "chattermatter.listComments",
        "title": "ChatterMatter: List Comments"
      },
      {
        "command": "chattermatter.stripComments",
        "title": "ChatterMatter: Strip All Comments"
      },
      {
        "command": "chattermatter.toggleOverlay",
        "title": "ChatterMatter: Toggle Comment Overlay"
      },
      {
        "command": "chattermatter.hostSession",
        "title": "ChatterMatter: Host Review Session",
        "icon": "$(broadcast)"
      },
      {
        "command": "chattermatter.joinSession",
        "title": "ChatterMatter: Join Review Session",
        "icon": "$(plug)"
      },
      {
        "command": "chattermatter.leaveSession",
        "title": "ChatterMatter: Leave Session",
        "icon": "$(close)"
      },
      {
        "command": "chattermatter.showPeers",
        "title": "ChatterMatter: Show Peers"
      },
      {
        "command": "chattermatter.deleteResolvedComments",
        "title": "ChatterMatter: Delete All Resolved Comments",
        "icon": "$(trash)"
      },
      {
        "command": "chattermatter.openReviewPanel",
        "title": "ChatterMatter: Open Review Panel",
        "icon": "$(preview)"
      },
      {
        "command": "chattermatter.showSessionMenu",
        "title": "ChatterMatter: Session Menu"
      },
      {
        "command": "chattermatter.copyInviteLink",
        "title": "ChatterMatter: Copy Invite Link",
        "icon": "$(link)"
      },
      {
        "command": "chattermatter.manageInvites",
        "title": "ChatterMatter: Manage Invite Links"
      },
      {
        "command": "chattermatter.resumeSession",
        "title": "ChatterMatter: Resume Previous Session",
        "icon": "$(history)"
      },
      {
        "command": "chattermatter.submitComment",
        "title": "Save Comment",
        "icon": "$(check)"
      },
      {
        "command": "chattermatter.replyToThread",
        "title": "Reply",
        "icon": "$(reply)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "chattermatter.hostSession",
          "when": "editorLangId == markdown && !chattermatter.isConnected",
          "group": "navigation"
        },
        {
          "command": "chattermatter.openReviewPanel",
          "when": "editorLangId == markdown && chattermatter.isConnected",
          "group": "navigation"
        },
        {
          "command": "chattermatter.leaveSession",
          "when": "editorLangId == markdown && chattermatter.isConnected",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "chattermatter.addComment",
          "when": "editorLangId == markdown && editorHasSelection",
          "group": "chattermatter"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "chattermatter.submitComment",
          "group": "inline",
          "when": "commentController == chattermatter"
        }
      ],
      "comments/comment/title": [
        {
          "command": "chattermatter.resolveComment",
          "group": "navigation",
          "when": "commentController == chattermatter"
        },
        {
          "command": "chattermatter.deleteComment",
          "group": "navigation",
          "when": "commentController == chattermatter"
        }
      ]
    },
    "configuration": {
      "title": "ChatterMatter",
      "properties": {
        "chattermatter.author": {
          "type": "string",
          "default": "",
          "description": "Default author name for new comments"
        },
        "chattermatter.mode": {
          "type": "string",
          "enum": [
            "inline",
            "sidecar"
          ],
          "default": "inline",
          "description": "Where to write new comments: inline in the .md file or in a .md.chatter sidecar"
        },
        "chattermatter.showResolved": {
          "type": "boolean",
          "default": false,
          "description": "Show resolved comments in the overlay"
        },
        "chattermatter.highlightColor": {
          "type": "string",
          "default": "rgba(255, 212, 0, 0.15)",
          "description": "Background color for commented text highlights"
        },
        "chattermatter.p2p.defaultPort": {
          "type": "number",
          "default": 4117,
          "description": "Default port for hosting P2P review sessions"
        },
        "chattermatter.p2p.displayName": {
          "type": "string",
          "default": "",
          "description": "Your display name for P2P review sessions"
        },
        "chattermatter.p2p.hostAddress": {
          "type": "string",
          "default": "",
          "description": "Host address for invite URLs (e.g., your VPN IP). Leave empty for auto-detection."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:tests": "esbuild src/test/suite/index.ts src/test/suite/extension.test.ts --bundle --outdir=dist/test/suite --external:vscode --external:chattermatter --format=cjs --platform=node --sourcemap && esbuild src/test/runTest.ts --bundle --outdir=dist/test --external:@vscode/test-electron --format=cjs --platform=node --sourcemap",
    "watch": "npm run build -- --watch",
    "lint": "tsc --noEmit",
    "test": "npm run build && npm run build:tests && node dist/test/runTest.js",
    "test:ci": "npm run build && npm run lint",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "chattermatter": "file:..",
    "marked": "^17.0.3"
  }
}
